"""
Publish the same oscillating joint-position setpoint as
franka_example_controllers' joint_impedance_example_controller, on the
"joint_state_setpoint" topic, to exercise fr3_motion's joint_impedance_controller.
"""

import math
import sys

import rclpy
from rclpy.duration import Duration
from rclpy.node import Node
from sensor_msgs.msg import JointState


class ExampleJointImpedanceCommander(Node):

    def __init__(self):
        super().__init__('example_joint_impedance_commander')
        self.declare_parameter('robot_type', 'fr3')
        self.declare_parameter('arm_prefix', '')
        self.declare_parameter('initial_state_timeout', 5.0)

        robot_type = self.get_parameter('robot_type').value
        arm_prefix = self.get_parameter('arm_prefix').value
        prefix = f'{arm_prefix}_' if arm_prefix else ''
        self._joint_names = [f'{prefix}{robot_type}_joint{i}' for i in range(1, 8)]

        self._publisher = self.create_publisher(JointState, 'joint_state_setpoint', 10)
        self._initial_positions = self._capture_initial_positions()

        self._start_time = self.get_clock().now()
        self.create_timer(0.01, self._publish_setpoint)
        self.get_logger().info('Publishing joint state setpoints.')

    def _capture_initial_positions(self):
        timeout = self.get_parameter('initial_state_timeout').value
        received = {}

        def callback(msg):
            for name, position in zip(msg.name, msg.position):
                received[name] = position

        sub = self.create_subscription(JointState, '/joint_states', callback, 10)
        deadline = self.get_clock().now() + Duration(seconds=timeout)
        while self.get_clock().now() < deadline and not all(
                name in received for name in self._joint_names):
            rclpy.spin_once(self, timeout_sec=0.1)
        self.destroy_subscription(sub)

        missing = [name for name in self._joint_names if name not in received]
        if missing:
            self.get_logger().error(
                f'Timed out waiting for current joint positions on /joint_states; missing '
                f'joints {missing}. Refusing to guess a starting configuration.')
            rclpy.shutdown()
            sys.exit(1)

        return [received[name] for name in self._joint_names]

    def _publish_setpoint(self):
        t = (self.get_clock().now() - self._start_time).nanoseconds / 1e9
        delta_angle = math.pi / 8.0 * (1 - math.cos(math.pi / 2.5 * t))

        positions = list(self._initial_positions)
        positions[3] += delta_angle  # joint 4
        positions[4] += delta_angle  # joint 5

        msg = JointState()
        msg.header.stamp = self.get_clock().now().to_msg()
        msg.name = self._joint_names
        msg.position = positions
        self._publisher.publish(msg)


def main(args=None):
    rclpy.init(args=args)
    node = ExampleJointImpedanceCommander()
    try:
        rclpy.spin(node)
    except KeyboardInterrupt:
        pass
    finally:
        node.destroy_node()
        rclpy.shutdown()


if __name__ == '__main__':
    main()
